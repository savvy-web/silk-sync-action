{
	"name": "@savvy-web/silk-sync-action",
	"version": "1.1.2",
	"private": true,
	"description": "GitHub Action to synchronize settings for repos using the Silk Suite system",
	"keywords": [
		"github-action",
		"repository-settings",
		"label-sync",
		"github-projects",
		"organization-management",
		"silk-suite"
	],
	"homepage": "https://github.com/savvy-web/silk-sync-action#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/silk-sync-action/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/silk-sync-action.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:prod --log-order=grouped",
		"build:prod": "github-action-builder build",
		"ci:build": "CI=\"true\" turbo run build:prod --log-order=grouped --output-logs=full",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"generate:schema": "tsx lib/scripts/generate-schema.ts && biome format --write silk.config.schema.json",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --pass-with-no-tests",
		"test:coverage": "vitest run --coverage --pass-with-no-tests",
		"test:watch": "vitest --watch --pass-with-no-tests",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsc --noEmit",
		"validate": "github-action-builder validate"
	},
	"dependencies": {
		"@effect/platform-node": "catalog:effect",
		"@savvy-web/github-action-effects": "^3.0.5",
		"effect": "catalog:effect"
	},
	"devDependencies": {
		"@savvy-web/github-action-builder": "^2.0.5",
		"@savvy-web/silk": "^3.2.1",
		"@vitest-agent/plugin": "^2.0.7"
	},
	"packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72",
	"engines": {
		"node": ">=24.11.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.5.0",
				"onFail": "ignore"
			}
		]
	}
}
