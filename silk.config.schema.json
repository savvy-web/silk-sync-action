{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Silk Sync Configuration",
	"description": "Configuration for the silk-sync workflow that standardizes repository labels and settings across the organization.",
	"$ref": "#/definitions/SilkConfig",
	"definitions": {
		"LabelDefinition": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string",
					"allOf": [
						{
							"minLength": 1
						},
						{
							"maxLength": 50,
							"description": "Label name (case-insensitive matching)"
						}
					]
				},
				"description": {
					"type": "string",
					"allOf": [
						{
							"maxLength": 100,
							"description": "Short label description"
						}
					]
				},
				"color": {
					"type": "string",
					"allOf": [
						{
							"pattern": "^[0-9a-fA-F]{6}$",
							"description": "Hex color without # prefix"
						}
					]
				}
			},
			"required": ["name", "description", "color"],
			"additionalProperties": false,
			"title": "Label Definition"
		},
		"RepositorySettings": {
			"type": "object",
			"properties": {
				"has_wiki": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"has_issues": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"has_projects": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"has_discussions": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"allow_merge_commit": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"allow_squash_merge": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"squash_merge_commit_title": {
					"anyOf": [
						{
							"type": "string",
							"enum": ["PR_TITLE", "COMMIT_OR_PR_TITLE"]
						},
						{
							"type": "null"
						}
					]
				},
				"squash_merge_commit_message": {
					"anyOf": [
						{
							"type": "string",
							"enum": ["PR_BODY", "COMMIT_MESSAGES", "BLANK"]
						},
						{
							"type": "null"
						}
					]
				},
				"allow_rebase_merge": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"allow_update_branch": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"delete_branch_on_merge": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"web_commit_signoff_required": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				},
				"allow_auto_merge": {
					"anyOf": [
						{
							"type": "boolean"
						},
						{
							"type": "null"
						}
					]
				}
			},
			"additionalProperties": false,
			"title": "Repository Settings",
			"description": "Repository settings to enforce"
		},
		"SilkConfig": {
			"type": "object",
			"properties": {
				"$schema": {
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "null"
						}
					],
					"description": "Path to the JSON schema file"
				},
				"labels": {
					"type": "array",
					"description": "Labels to sync across repositories",
					"items": {
						"$ref": "#/definitions/LabelDefinition"
					}
				},
				"settings": {
					"$ref": "#/definitions/RepositorySettings"
				}
			},
			"required": ["labels", "settings"],
			"additionalProperties": false,
			"title": "Silk Config",
			"description": "Organization-wide sync configuration"
		}
	}
}
